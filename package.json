{
  "name": "@qubit-ltd/naming-style",
  "version": "1.3.13",
  "description": "A JavaScript library for converting between different naming styles of identifiers.",
  "author": "Haixing Hu",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qubit-ltd/js-naming-style.git"
  },
  "bugs": {
    "url": "https://github.com/qubit-ltd/js-naming-style/issues"
  },
  "homepage": "https://github.com/qubit-ltd/js-naming-style",
  "keywords": [
    "javascript",
    "string",
    "case",
    "conversion",
    "naming style"
  ],
  "main": "dist/naming-style.min.cjs",
  "module": "dist/naming-style.min.mjs",
  "exports": {
    ".": {
      "require": "./dist/naming-style.min.cjs",
      "import": "./dist/naming-style.min.mjs"
    }
  },
  "files": [
    "dist/**/*",
    "doc/**/*",
    "LICENSE",
    "README.md",
    "README.zh_CN.md"
  ],
  "scripts": {
    "clean": "rm -rvf dist doc",
    "build": "cross-env NODE_ENV=production rollup -c rollup.config.mjs",
    "build:dev": "cross-env NODE_ENV=development rollup -c rollup.config.mjs",
    "build:all": "yarn clean && yarn build:dev && yarn build && yarn doc",
    "test": "jest",
    "lint": "eslint ./src ./test",
    "doc": "jsdoc -c jsdoc.json",
    "es5": "check-es-version -e 5 -s true",
    "deploy": "npm run lint && npm run test && npm run build:all && npm publish --@qubit-ltd:registry='https://registry.npmjs.org/' --access public"
  },
  "browserify": {
    "transform": [
      "babelify"
    ]
  },
  "peerDependencies": {
    "@babel/runtime": "^7.26.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/eslint-parser": "^7.28.4",
    "@babel/plugin-transform-class-properties": "^7.27.1",
    "@babel/plugin-transform-runtime": "^7.28.3",
    "@babel/preset-env": "^7.28.3",
    "@babel/runtime": "^7.28.4",
    "@jest/core": "^30.1.3",
    "@qubit-ltd/eslint-config": "^2.0.2",
    "@qubit-ltd/jsdoc-theme": "^1.5.3",
    "@qubit-ltd/rollup-builder": "^1.8.15",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "babel-jest": "^29.7.0",
    "check-es-version": "^1.5.1",
    "core-js": "^3.45.1",
    "cross-env": "^10.0.0",
    "eslint": "^9.35.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^10.4.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-extended": "^6.0.0",
    "jsdoc": "^4.0.4",
    "rollup": "^4.50.1",
    "rollup-plugin-analyzer": "^4.0.0",
    "rollup-plugin-visualizer": "^6.0.3",
    "typescript": "^5.9.2",
    "vue-eslint-parser": "^10.2.0"
  },
  "packageManager": "yarn@4.5.0"
}
